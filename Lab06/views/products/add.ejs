<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Thêm sản phẩm mới</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="main-content form-container">
        <h1 class="title">THÊM SẢN PHẨM MỚI</h1>

        <form action="/add" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="id">ID</label>
                <input type="text" id="id" name="ID" placeholder="Nhập mã sản phẩm...">
            </div>

            <div class="form-group">
                <label for="name">Tên</label>
                <input type="text" id="name" name="name" placeholder="Nhập tên sản phẩm...">
            </div>

            <div class="form-group">
                <label for="price">Giá</label>
                <input type="number" id="price" name="price" placeholder="0.00">
            </div>

            <div class="form-group">
                <label for="unit_in_stock">Tồn kho</label>
                <input type="number" id="unit_in_stock" name="unit_in_stock" placeholder="0">
            </div>

            <div class="form-group">
                <label for="image">Ảnh</label>
                <input type="file" id="image" name="image">
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">Thêm ngay</button>
                <a href="/" class="btn-back">Quay lại</a>
            </div>
        </form>
    </div>
</body>

</html>