<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Product List</title>
    <link rel="stylesheet" href="/style.css">

</head>

<body>
    <h2>Add Product</h2>

    <form action="/add" method="post" class="form-add">
        <div class="form-group">
            <label>Name</label>
            <input name="name">
        </div>

        <div class="form-group">
            <label>Price</label>
            <input name="price">
        </div>

        <div class="form-group">
            <label>Quantity</label>
            <input name="quantity">
        </div>

        <button>Add</button>
    </form>


    <h2>Search Product</h2>

    <form method="get" action="/">
        <input type="text" name="keyword" placeholder="Enter product name" value="<%= keyword %>">
        <button>Search</button>
    </form>

    <hr>

    <h2>Products</h2>
    <table border="1">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Action</th>
        </tr>

        <% products.forEach(p => { %>
            <tr>
                <td>
                    <%= p.id %>
                </td>
                <td>
                    <%= p.name %>
                </td>
                <td>
                    <%= p.price %>
                </td>
                <td>
                    <%= p.quantity %>
                </td>
                <td class="action">
                    <a href="/edit/<%= p.id %>" class="edit-btn">Edit</a>

                    <form action="/delete/<%= p.id %>" method="post" class="inline-form">
                        <button class="delete-btn" onclick="return confirm('Delete this product?')">
                            Delete
                        </button>
                    </form>
                </td>


            </tr>
            <% }) %>
    </table>

</body>

</html>