<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="main-content">
        <h1 class="title">DANH SÁCH SẢN PHẨM</h1>

        <div class="top-bar">
            <form action="/search" method="GET" class="search-form">
                <input type="text" name="keyword" placeholder="Tìm kiếm..." value="<%= typeof query !== 'undefined' ? query : '' %>">
                <button type="submit" class="btn-search">Tìm</button>
            </form>

            <a href="/add" class="btn-add">+ Thêm sản phẩm</a>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
            <% } %>

                <table class="product-table">
                    <thead>
                        <tr>
                            <th style="width: 10%;">ID</th>
                            <th style="width: 25%;">Tên</th>
                            <th style="width: 15%;">Ảnh</th>
                            <th style="width: 15%;">Giá</th>
                            <th style="width: 10%;">Tồn kho</th>
                            <th style="width: 25%;">Xử lý</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach(product => { %>
                            <tr>
                                <td>
                                    <%= product.ID %>
                                </td>
                                <td>
                                    <%= product.name %>
                                </td>
                                <td>
                                    <% if (product.url_image || product.image) { %>
                                        <img src="<%= product.url_image || product.image %>" class="img-thumb" style="width: 50px; height: 50px; object-fit: cover;">
                                        <% } else { %>
                                            <span class="text-muted">Không ảnh</span>
                                            <% } %>
                                </td>
                                <td>
                                    <%= product.price %>
                                </td>
                                <td>
                                    <%= product.unit_in_stock %>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/details/<%= product.ID %>" class="btn btn-sm btn-info text-white">Xem</a>

                                        <a href="/edit/<%= product.ID %>" class="btn-edit">Sửa</a>

                                        <a href="/delete/<%= product.ID %>" class="btn-delete" style="text-decoration: none; display: inline-block; padding: 5px 10px; background: #dc3545; color: white; border-radius: 4px;" onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm <%= product.name %>?')">
                                   Xóa
                                </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>

                <% if (products.length === 0) { %>
                    <p class="text-center mt-4 text-muted">Không có sản phẩm nào để hiển thị.</p>
                    <% } %>
    </div>

</body>

</html>