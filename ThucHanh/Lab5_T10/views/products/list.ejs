<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="main-content">
        <h1 class="title">DANH SÁCH SẢN PHẨM</h1>

        <div class="top-bar">
            <form action="/search" method="GET" class="search-form">
                <input type="text" name="keyword" placeholder="Tìm kiếm..." value="<%= typeof query !== 'undefined' ? query : '' %>">
                <button type="submit" class="btn-search">Tìm</button>
            </form>
            
            <a href="/add" class="btn-add">+ Thêm sản phẩm</a>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <table class="product-table">
            <thead>
                <tr>
                    <th style="width: 10%;">ID</th>
                    <th style="width: 25%;">Tên</th>
                    <th style="width: 15%;">Ảnh</th>
                    <th style="width: 15%;">Giá</th>
                    <th style="width: 10%;">Số lượng</th>
                    <th style="width: 25%;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(product => { %>
                <tr>
                    <td><%= product.ID %></td>
                    <td><%= product.name %></td>
                    <td>
                        <% if (product.image) { %>
                            <img src="<%= product.image %>" class="img-thumb">
                        <% } else { %>
                            <span class="text-muted">Không có ảnh</span>
                        <% } %>
                    </td>
                    <td><%= product.price %></td>
                    <td><%= product.quantity %></td>
                    <td>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="/edit/<%= product.ID %>" class="btn-edit">Sửa</a>
                            
                            <form method="POST" action="/delete/<%= product.ID %>" 
                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm <%= product.name %>?')">
                                <button type="submit" class="btn-delete">Xóa</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <% if (products.length === 0) { %>
            <p class="text-center mt-4 text-muted">Không có sản phẩm nào để hiển thị.</p>
        <% } %>
    </div>

</body>
</html>