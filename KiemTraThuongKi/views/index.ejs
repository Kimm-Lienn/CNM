<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý vé sự kiện</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header>
        <h1> Quản lý sự kiện vé </h1>
        <div class="actions">
            <a href="/add" class="btn btn-primary">+ Thêm vé mới</a>
        </div>
    </header>

    <section class="filter-section">
        <form method="GET" action="/">
            <input type="text" name="search" placeholder="Tìm tên sự kiện hoặc khách hàng...">
            <select name="status">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="Upcoming">Upcoming</option>
                <option value="Sold">Sold</option>
                <option value="Cancelled">Cancelled</option>
            </select>
            <button type="submit" class="btn btn-search">Tìm kiếm</button>
            <a href="/" class="btn btn-reset">Làm mới</a>
        </form>
    </section>

    <div class="card-container">
        <% if (tickets.length > 0) { %>
            <% tickets.forEach(ticket => { %>
                <div class="ticket-card">
                    <div class="card-image">
                        <img src="<%= ticket.imageUrl || 'https://via.placeholder.com/300x150' %>" alt="Ticket Image">
                        <span class="status-badge <%= ticket.status ? ticket.status.toLowerCase() : 'unknown' %>">
                            <%= ticket.status || 'Chưa xác định' %>
                        </span>
                    </div>
                    <div class="card-content">
                        <h3 class="event-name">
                            <%= ticket.eventName %>
                        </h3>
                        <p class="holder-name"> <strong><%= ticket.holderName %></strong></p>
                        <div class="ticket-info">
                            <span><%= ticket.eventDate %></span>
                            <span><%= ticket.category %> (x<%= ticket.quantity %>)</span>
                        </div>
                        <div class="price-section">
                            <p class="final-price">
                                <p class="final-price">
                                    <%= ticket.finalAmount ? ticket.finalAmount.toLocaleString() : '0' %> VND
                                </p>
                                <% if (ticket.promoLabel === "Được giảm giá") { %>
                                    <span class="promo-badge">Giảm giá áp dụng</span>
                                    <% } %>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/edit/<%= ticket.ticketId %>" class="btn-edit">Sửa</a>
                        <form action="/delete/<%= ticket.ticketId %>" method="POST" onsubmit="return confirm('Xóa vé này?')">
                            <button type="submit" class="btn-delete">Xóa</button>
                        </form>
                    </div>
                </div>
                <% }) %>
                    <% } else { %>
                        <p style="text-align: center; width: 100%;">Không tìm thấy vé nào.</p>
                        <% } %>
    </div>
</body>

</html>