<div class="main-content form-container">
    <h1 class="title">CẬP NHẬT SẢN PHẨM</h1>

    <form action="/edit/<%= product.ID %>" method="POST" enctype="multipart/form-data">

        <div class="form-group">
            <label>Tên sản phẩm</label>
            <input type="text" name="name" value="<%= product.name %>" required>
        </div>

        <div class="form-group">
            <label>Giá</label>
            <input type="number" name="price" value="<%= product.price %>" required>
        </div>

        <div class="form-group">
            <label>Tồn kho</label>
            <input type="number" name="unit_in_stock" value="<%= product.unit_in_stock || product.quantity %>" required>
        </div>

        <div class="form-group">
            <label>Ảnh hiện tại</label>
            <img src="<%= product.url_image || product.image %>" width="100" style="display:block; margin-bottom:10px;">
            <input type="file" name="image">
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Cập nhật</button>
            <a href="/" class="btn-back">Hủy</a>
        </div>
    </form>
</div>