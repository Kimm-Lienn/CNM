<!DOCTYPE html>
<html>
<head>
  <title>Quản lý sản phẩm</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">
  <h1>Quản lý sản phẩm</h1>
  
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <!-- Tìm kiếm -->
  <form class="mb-4" method="GET">
    <div class="input-group">
      <input type="text" name="search" class="form-control" placeholder="Tìm theo tên" value="<%= query %>">
      <button class="btn btn-primary">Tìm</button>
    </div>
  </form>

  <a href="/add" class="btn btn-success mb-3">+ Thêm sản phẩm mới</a>

  <table class="table table-bordered">
    <thead class="table-dark">
      <tr>
        <th>ID</th><th>Tên</th><th>Hình ảnh</th><th>Giá</th><th>Số lượng</th><th>Hành động</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(p => { %>
      <tr>
        <td><%= p.ID %></td>
        <td><%= p.name %></td>
        <td>
          <% if (p.image) { %>
            <img src="<%= p.image %>" width="80" height="80" style="object-fit:cover">
          <% } else { %>
            <span class="text-muted">Không có ảnh</span>
          <% } %>
        </td>
        <td><%= p.price %> đ</td>
        <td><%= p.quantity %></td>
        <td>
          <a href="/edit/<%= p.ID %>" class="btn btn-warning btn-sm">Sửa</a>
          <form method="POST" action="/delete/<%= p.ID %>" style="display:inline;" 
                onsubmit="return confirm('Xóa sản phẩm <%= p.name %>?')">
            <button class="btn btn-danger btn-sm">Xóa</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>